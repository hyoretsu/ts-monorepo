// biome-ignore-all assist/source/useSortedKeys: order matters here
{
	"compilerOptions": {
		"paths": {
			"@utils": ["./src/shared/utils"],
			"@utils/*": ["./src/shared/utils/*"],
			"@/*": ["./src/*"]
		}
	},
	"extends": ["@hyoretsu/configs/ts"],
	// Only type-check source — never the bundled `dist/` output (it's emitted JS).
	"include": ["src"],
	"exclude": ["dist", "node_modules"]
}
